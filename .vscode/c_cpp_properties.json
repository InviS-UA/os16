{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_cdecl="
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c99",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-ffreestanding -nostdlib -mcmodel=small \"-D_cdecl=__attribute__((cdecl))\""
            ]
        }
    ],
    "version": 4
}